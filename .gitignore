# Dependencies installed by npm (re-created by `npm install`, never committed)
/node_modules

# Next.js build output and caches
/.next
/out
/build
.turbo

# Vercel local files
.vercel

# Environment variable files (may contain secrets — keep these out of git)
.env
.env*.local

# Debug logs from npm/yarn/pnpm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript's auto-generated file (this is a JS project, but harmless to ignore)
next-env.d.ts

# Local, machine-specific Claude Code settings (personal, not shared)
.claude/settings.local.json

# System / editor files
.DS_Store
